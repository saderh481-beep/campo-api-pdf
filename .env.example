# Puerto donde correra la API
PORT=3002

# JWT Secret (mismo que campo-api-web)
JWT_SECRET=your-jwt-secret-here

# API Keys para servicios internos
API_KEY_WEB=web-service-key-12345
API_KEY_APP=app-service-key-67890

# Configuracion del pool de navegadores
BROWSER_MAX_PAGES=3
BROWSER_TIMEOUT=30000
BROWSER_IMG_TIMEOUT=10000

# Chromium (@sparticuz/chromium-min)
CHROMIUM_PATH=

# Logging
LOG_LEVEL=info