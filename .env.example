# Puerto donde correra la API (Railway usa 8080)
PORT=8080

# JWT Secret (debe ser igual que en campo-api-web)
JWT_SECRET=your-jwt-secret-here-minimo-32-caracteres

# API Key para la web
API_KEY_WEB=web-service-key-12345

# Configuracion del pool de navegadores
BROWSER_MAX_PAGES=3
BROWSER_TIMEOUT=30000
BROWSER_IMG_TIMEOUT=10000

# Chromium (@sparticuz/chromium-min)
CHROMIUM_PATH=

# Logging
LOG_LEVEL=info