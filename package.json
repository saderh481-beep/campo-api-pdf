{
  "name": "campo-api-pdf",
  "version": "1.0.0",
  "description": "API generadora de PDFs para bitácoras de campo",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --target bun --outdir ./dist",
    "docker:build": "docker build -t campo-api-pdf .",
    "docker:run": "docker run -p 3002:3002 --env-file .env campo-api-pdf"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.1",
    "@hono/zod-validator": "^0.7.6",
    "@sparticuz/chromium-min": "^147.0.2",
    "hono": "^4.1.0",
    "jose": "^6.2.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "puppeteer-core": "^24.42.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.1.13",
    "bun-types": "^1.1.33",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}